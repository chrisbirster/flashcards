{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": [
      "node",
      "aws-lambda"
    ]
  },
  "include": [
    "functions/**/*.ts",
    "sst.config.ts",
    "sst-env.d.ts"
  ]
}
